# Copy to .env and fill in. Never commit .env.

# obs-websocket password (shared by obs, watchdog, dashboard).
# Generate with: openssl rand -hex 16
OBS_WS_PASSWORD=change-me

# Credentials your phone app uses to publish into MediaMTX.
# SRT/SRTLA streamid becomes:  publish:live:<user>:<pass>
# RTMP URL becomes:            rtmp://<server>/live?user=<user>&pass=<pass>
PUBLISH_USER=streamer
PUBLISH_PASS=change-me

# Dashboard login (Caddy basic auth).
# Generate the hash with: docker compose run --rm caddy caddy hash-password
DASH_USER=admin
DASH_PASS_HASH=change-me

# Optional: a domain pointing at this server for real TLS certificates.
# Leave unset to use Caddy's self-signed internal CA (browser warning, still encrypted).
#DOMAIN=stream.example.com
